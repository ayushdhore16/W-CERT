@app.route('/report', methods=['POST'])
def handle_incident():
    data = request.json
    
    # 1. Extraction
    name = data.get('name', 'Anonymous')
    contact = data.get('contact', 'N/A')
    description = data.get('description', '')

    # 2. Logic: Perform Analysis
    score, severity, tags = perform_threat_analysis(description)

    # 3. Security: AES Encryption for PII (Data at Rest Protection)
    encrypted_name = cipher.encrypt(name.encode()).decode()
    encrypted_contact = cipher.encrypt(contact.encode()).decode()

    # 4. Security: SHA-256 for Forensic Integrity
    content_hash = hashlib.sha256(description.encode()).hexdigest()
    
    # 5. Compile and Store
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    # Structure for Google Sheet: 
    # [Time, Encrypted_Name, Encrypted_Contact, Tags, Score, Severity, Hash]
    final_row = [timestamp, encrypted_name, encrypted_contact, tags, score, severity, content_hash]
    
    if save_to_secure_sheet(final_row):
        return jsonify({
            "status": "Success",
            "incident_id": content_hash[:10].upper(),
            "severity": severity,
            "analysis_score": score,
            "message": "Report logged securely with end-to-end encryption."
        }), 200
    else:
        return jsonify({"status": "Database Connection Failed"}), 500

