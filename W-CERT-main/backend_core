# 2. THE CORE LOGIC ENGINE
# ==========================================
def perform_threat_analysis(description):
    """
    Weighted Keyword Analysis for Phishing/Social Engineering
    """
    score = 0
    desc = description.lower()
    
    # Dictionary of weights based on Women-Centric Cyber Threats
    weights = {
        "leak": 35, "private": 25, "photos": 30, "threat": 25,
        "money": 15, "urgent": 15, "password": 20, "otp": 20,
        "police": 10, "blocked": 10
    }

    detected_tags = []
    for word, weight in weights.items():
        if word in desc:
            score += weight
            detected_tags.append(word)

    # Severity Categorization
    if score >= 75: severity = "CRITICAL"
    elif score >= 50: severity = "HIGH"
    elif score >= 25: severity = "MEDIUM"
    else: severity = "LOW"
    
    return score, severity, ", ".join(detected_tags)

