# Flask
SECRET_KEY=your-secret-key-here
FLASK_ENV=development
FLASK_DEBUG=1

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-here

# AES Encryption Key (Fernet) - generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Google Sheets
SERVICE_ACCOUNT_PATH=../service_account.json
SPREADSHEET_NAME=W-CERT_Database

# Evidence Storage
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760
